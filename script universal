local function animateGUI(open)
    local targetSize = open and UDim2.new(0, 500, 0, 600) or UDim2.new(0, 0, 0, 0)
    local targetPos = open and UDim2.new(0.5, -250, 0.5, -300) or UDim2.new(0.5, -250, 0.5, -300)
    local targetTrans = open and 0.05 or 1
    
    local tween = TweenService:Create(MainFrame, tweenInfo, {
        Size = targetSize,
        BackgroundTransparency = targetTrans
    })
    tween:Play()
    
    TweenService:Create(MainShadow, tweenInfo, {
        Size = targetSize + UDim2.new(0, 20, 0, 20),
        Position = MainFrame.Position - UDim2.new(0, 10, 0, 10)
    }):Play()
    
    tween.Completed:Connect(function()
        if not open then
            MainFrame.Visible = false
            MainShadow.Visible = false
        else
            MainFrame.Visible = true
            MainShadow.Visible = true
        end
    end)
