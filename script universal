-- Função para copiar skin (simplificada)
local function copySkin(username)
    if not username or username == "" then
        statusLabel.Text = "Digite um username!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(2)
        statusLabel.Text = "Aguardando..."
        statusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        return
    end
    
    statusLabel.Text = "Buscando jogador..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    
    local player = Players:FindFirstChild(username)
    if not player then
        statusLabel.Text = "Jogador não encontrado!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(2)
        statusLabel.Text = "Aguardando..."
        statusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        return
    end
    
    if not player.Character then
        statusLabel.Text = "Jogador não está no jogo!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(2)
        statusLabel.Text = "Aguardando..."
        statusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        return
    end
    
    statusLabel.Text = "Copiando skin..."
    
    local localChar = LocalPlayer.Character
    if not localChar then
        waitForCharacter()
        localChar = LocalPlayer.Character
    end
    
    local targetChar = player.Character
    
    -- Copiar roupas
    local function copyClothing()
        for _, clothing in pairs(targetChar:GetChildren()) do
            if clothing:IsA("Shirt") or clothing:IsA("Pants") or clothing:IsA("ShirtGraphic") then
                local newClothing = clothing:Clone()
                newClothing.Parent = localChar
            end
        end
    end
    
    -- Copiar acessórios
    local function copyAccessories()
        for _, accessory in pairs(targetChar:GetChildren()) do
            if accessory:IsA("Accessory") then
                local newAccessory = accessory:Clone()
                newAccessory.Parent = localChar
            end
        end
    end
    
    -- Remover roupas antigas
    for _, child in pairs(localChar:GetChildren()) do
        if child:IsA("Shirt") or child:IsA("Pants") or child:IsA("ShirtGraphic") or child:IsA("Accessory") then
            child:Destroy()
        end
    end
    
    copyClothing()
    copyAccessories()
    
    statusLabel.Text = "Skin copiada com sucesso!"
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    
    task.wait(2)
    statusLabel.Text = "Aguardando..."
    statusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
end

